{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "A backend service that analyzes GitHub user profiles and stores insights in MySQL.",
    "_postman_id": "github-profile-analyzer-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏠 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Check if the API server is running"
      }
    },
    {
      "name": "🔍 Analyze GitHub Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/analyze/torvalds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "analyze", "torvalds"]
        },
        "description": "Fetch a GitHub user profile and store insights in the database. Replace 'torvalds' with any GitHub username."
      }
    },
    {
      "name": "📋 List All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles?page=1&limit=10&sort=analyzed_at&order=DESC",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles"],
          "query": [
            { "key": "page", "value": "1", "description": "Page number" },
            { "key": "limit", "value": "10", "description": "Results per page" },
            { "key": "sort", "value": "analyzed_at", "description": "Sort by: analyzed_at, followers, public_repos, username" },
            { "key": "order", "value": "DESC", "description": "Order: ASC or DESC" }
          ]
        },
        "description": "Retrieve all stored profiles with pagination support"
      }
    },
    {
      "name": "👤 Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/torvalds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "torvalds"]
        },
        "description": "Get full details and insights for a single stored profile"
      }
    },
    {
      "name": "🗑️ Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/torvalds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "torvalds"]
        },
        "description": "Delete a profile and all its related data from the database"
      }
    },
    {
      "name": "⚔️ Compare Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/compare?users=torvalds,gaearon,sindresorhus",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "compare"],
          "query": [
            { "key": "users", "value": "torvalds,gaearon,sindresorhus", "description": "Comma-separated GitHub usernames (must be already analyzed)" }
          ]
        },
        "description": "Compare multiple GitHub profiles side by side"
      }
    },
    {
      "name": "📊 Overall Stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/stats",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stats"]
        },
        "description": "Get overall statistics: top users, top languages, total profiles analyzed"
      }
    },
    {
      "name": "⏱️ GitHub Rate Limit",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/rate-limit",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rate-limit"]
        },
        "description": "Check remaining GitHub API rate limit"
      }
    },
    {
      "name": "🔍 Analyze - Linus Torvalds",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/analyze/torvalds",
          "host": ["{{baseUrl}}"],
          "path": ["api", "analyze", "torvalds"]
        }
      }
    },
    {
      "name": "🔍 Analyze - Dan Abramov",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/analyze/gaearon",
          "host": ["{{baseUrl}}"],
          "path": ["api", "analyze", "gaearon"]
        }
      }
    },
    {
      "name": "🔍 Analyze - Sindre Sorhus",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/analyze/sindresorhus",
          "host": ["{{baseUrl}}"],
          "path": ["api", "analyze", "sindresorhus"]
        }
      }
    }
  ]
}
